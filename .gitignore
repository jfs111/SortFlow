# ============================================
# SortFlow Project - .gitignore
# ============================================

# ============================================
# CRITICAL - Environment files with secrets
# ============================================
# ALWAYS exclude .env files (contain API keys, secrets, passwords)
.env
.env.local
.env.*.local
sortflow_web_service/.env
sortflow_ml_service/.env

# ============================================
# Python
# ============================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff
instance/
.webassets-cache

# Scrapy stuff
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ============================================
# SortFlow Specific - Web Service
# ============================================

# User uploaded images (IMPORTANT - can be very large)
sortflow_web_service/uploads/projects/*/
sortflow_web_service/uploads/projects/**/*

# Keep the directory structure but ignore content
!sortflow_web_service/uploads/projects/.gitkeep

# SQLite databases (contain user data)
sortflow_web_service/instance/*.db
sortflow_web_service/instance/*.sqlite
sortflow_web_service/instance/*.sqlite3

# Logs
sortflow_web_service/logs/
sortflow_web_service/*.log

# ============================================
# SortFlow Specific - ML Service
# ============================================

# ML Service data directories
sortflow_ml_service/data/
sortflow_ml_service/embeddings/
sortflow_ml_service/models/
sortflow_ml_service/temp/
sortflow_ml_service/visualizations/

# Logs
sortflow_ml_service/logs/
sortflow_ml_service/*.log

# ============================================
# C# / .NET - SortFlowApiTester
# ============================================

# Build results
SortFlowApiTester/bin/
SortFlowApiTester/obj/
SortFlowApiTester/[Dd]ebug/
SortFlowApiTester/[Dd]ebugPublic/
SortFlowApiTester/[Rr]elease/
SortFlowApiTester/[Rr]eleases/
SortFlowApiTester/x64/
SortFlowApiTester/x86/
SortFlowApiTester/[Ww][Ii][Nn]32/
SortFlowApiTester/[Aa][Rr][Mm]/
SortFlowApiTester/[Aa][Rr][Mm]64/
SortFlowApiTester/bld/

